<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.PoS.Views.TablesMainView"
             Title="TablesMainView"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout>
        <CollectionView
            ItemsSource="{Binding Tables}"
            SelectedItem="{Binding SelectedTable}"
            SelectionMode="Single"
            >
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="ID:"/>
                                <Label Grid.Column="1" Text="{Binding Id}"/>
                            </Grid>

                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="Capacity:"/>
                                <Label Grid.Column="1" Text="{Binding Capacity}"/>
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="Current:"/>
                                <Label Grid.Column="1" Text="{Binding CurrentPartySize}"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="Add New" Clicked="AddNewClicked"/>
        <!--<Button Text="Edit Item" Clicked="EditClicked"/>-->
        <Button Text="Delete Item" Clicked="DeleteClicked"/>
        <Button Text="Go Back" Clicked="GoBackClicked"/>
    </VerticalStackLayout>
</ContentPage>